# App
NODE_ENV=
DATABASE_URL="file:./prisma/dev.db"

# FINLIFE (server-only)
FINLIFE_API_KEY=
FINLIFE_BASE_URL=
FINLIFE_MODE=
FINLIFE_FAIL_OPEN_TO_MOCK=
FINLIFE_TOPFIN_GRP_LIST=
FINLIFE_SNAPSHOT_TTL_SECONDS=
FINLIFE_SCAN_HARD_CAP_PAGES=
FINLIFE_CACHE_TTL_SECONDS=
FINLIFE_FIXTURE_DIR=
FINLIFE_RECORD_FIXTURES=

# Public APIs (server-only)
PUBLIC_APIS_FALLBACK_TO_MOCK=
KDB_DATAGO_SERVICE_KEY=
DATAGO_SERVICE_KEY= # optional fallback
KEXIM_API_KEY=
KEXIM_FX_API_URL=
MOLIT_SALES_API_KEY=
MOLIT_SALES_API_URL=
MOLIT_RENT_API_KEY=
MOLIT_RENT_API_URL=
MOIS_BENEFITS_API_KEY=
MOIS_BENEFITS_API_URL=
REB_SUBSCRIPTION_API_KEY=
REB_SUBSCRIPTION_API_URL=
BOK_ECOS_API_KEY=
ECOS_LANGUAGE=kr
ECOS_MAX_ROWS=100
ECOS_ENABLED=true
PLANNING_PDF_ENABLED=false

# OpenDART (server-only)
OPENDART_API_KEY=
OPENDART_BASE_URL=
DART_CORPCODES_INDEX_PATH=
DART_INDEX_BUILD_TOKEN=

# Cache
API_CACHE_STORE=
API_FILE_CACHE_DIR=

# Prisma engine/network (optional)
# 프록시 URL에 계정정보가 포함될 수 있으므로 로그에 값 전체를 출력하지 마세요.
PRISMA_ENGINES_MIRROR=
PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# GitHub Ops (Dev)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
PLANNING_FEEDBACK_ISSUE_LABELS=planning,feedback
PLANNING_FEEDBACK_ISSUE_PREFIX=[Planning v2]
AUTO_MERGE_ENABLED=false
AUTO_MERGE_REQUIRED_CHECKS=CI
AUTO_MERGE_REQUIRED_LABEL=automerge
AUTO_MERGE_MIN_APPROVALS=0
AUTO_MERGE_REQUIRE_CLEAN=false
AUTO_MERGE_CONFIRM_TEMPLATE=MERGE {PR} {SHA7}
AUTO_MERGE_POLICY_PATH=.data/ops/auto-merge-policy.json
