{
  "name": "finance",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/next_dev_safe.mjs",
    "dev:lan": "node scripts/next_dev_safe.mjs --host 0.0.0.0",
    "dev:raw": "next dev",
    "build": "next build --webpack",
    "build:turbopack": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "pnpm exec tsc --noEmit",
    "test": "vitest run",
    "smoke:benefits": "node scripts/smoke_benefits.mjs",
    "env:setup": "node scripts/env_setup.mjs",
    "env:doctor": "node scripts/env_doctor.mjs",
    "offline:doctor": "node scripts/offline_doctor.mjs",
    "dart:corpindex": "python3 scripts/dart_corpcode_build.py",
    "dart:ensure-corpindex": "node scripts/dart_ensure_corpindex.mjs",
    "dart:watch": "node scripts/dart_disclosure_watch.mjs",
    "dart:watch:alerts": "node scripts/dart_disclosure_watch.mjs",
    "dart:watch:strict": "node scripts/dart_disclosure_watch.mjs --strict",
    "dart:watch:strict-high": "node scripts/dart_disclosure_watch.mjs --strict-high",
    "providers:logos:import": "node scripts/providers-logos-import.mjs",
    "providers:manifest": "node scripts/providers-manifest.mjs",
    "e2e": "playwright test",
    "e2e:rc": "playwright test tests/e2e/smoke.spec.ts tests/e2e/flow-planner-to-history.spec.ts tests/e2e/flow-history-to-report.spec.ts tests/e2e/dart-flow.spec.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:pw": "playwright test",
    "e2e:legacy": "node scripts/e2e_run.mjs",
    "e2e:docker": "node scripts/e2e_docker.mjs",
    "finlife:probe": "node scripts/finlife_probe_groups.mjs",
    "finlife:sync": "node scripts/finlife_sync.mjs",
    "finlife:sync:if-stale": "node scripts/finlife_sync_if_stale.mjs",
    "finlife:backfill-norms": "node scripts/finlife_backfill_norms.mjs",
    "artifacts:prune": "node scripts/artifacts_prune.mjs --keep=10",
    "fixtures:refresh:finlife": "node scripts/fixtures_refresh_finlife.mjs --kind=deposit --take=10",
    "validate:dumps": "node scripts/validate_dumps.mjs --mode=all",
    "validate:dumps:fixtures": "node scripts/validate_dumps.mjs --mode=fixtures",
    "schema:report": "node scripts/schema_drift_report.mjs",
    "schema:update": "node scripts/schema_drift_report.mjs --update",
    "freshness:report": "node scripts/data_freshness_report.mjs",
    "data:doctor": "pnpm schema:report && pnpm freshness:report",
    "verify": "pnpm validate:dumps:fixtures && pnpm data:doctor && pnpm lint && pnpm typecheck && pnpm test",
    "prisma:generate": "node scripts/prisma_cli_safe.mjs generate",
    "prisma:debug": "node scripts/prisma_cli_safe.mjs debug",
    "deps:approve-builds": "node scripts/approve_builds.mjs",
    "deps:offline:fetch": "node scripts/deps_offline.mjs fetch",
    "deps:offline:install": "node scripts/deps_offline.mjs install",
    "deps:offline:install:build": "node scripts/deps_offline.mjs install --build-from-source",
    "bootstrap:local": "node scripts/bootstrap_local.mjs",
    "datago:sync": "node scripts/datago_sync.mjs",
    "seed:debug": "node scripts/seed_debug.mjs",
    "seed:kdb": "pnpm datago:sync --source=kdb --kind=deposit --fromFile=tests/fixtures/kdb-deposit.sample.xml",
    "live:smoke": "node scripts/live_verify.mjs --mode=smoke",
    "live:sync": "node scripts/live_verify.mjs --mode=full",
    "products:sync": "pnpm finlife:sync && pnpm datago:sync",
    "gov24:sync": "tsx scripts/gov24_sync.ts",
    "gov24:sync:if-stale": "tsx scripts/gov24_sync_if_stale.ts",
    "provider:scaffold": "node scripts/provider_scaffold.mjs",
    "warm:if-stale": "node scripts/warm_if_stale.mjs",
    "warm:offline": "node scripts/warm_if_stale.mjs --offline",
    "daily:refresh": "node scripts/daily_refresh.mjs",
    "daily:refresh:strict": "node scripts/daily_refresh.mjs --strict"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^17.3.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "iconv-lite": "^0.7.2",
    "prisma": "^7.4.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "yauzl": "^3.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "esbuild",
      "prisma"
    ]
  }
}
