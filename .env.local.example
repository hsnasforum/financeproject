# Public APIs (server-only)
KDB_DATAGO_SERVICE_KEY=
DATAGO_SERVICE_KEY= # optional fallback
KEXIM_API_KEY=
MOLIT_SALES_API_KEY=
MOLIT_SALES_API_URL=
MOLIT_RENT_API_KEY=
MOLIT_RENT_API_URL=
MOIS_BENEFITS_API_KEY=
MOIS_BENEFITS_API_URL=https://api.odcloud.kr/api
REB_SUBSCRIPTION_API_KEY=
REB_SUBSCRIPTION_API_URL=https://api.odcloud.kr/api
OPENDART_API_KEY=
EXIM_EXCHANGE_API_KEY=
EXIM_EXCHANGE_API_URL=
# NOTE: infuser.odcloud.kr/.../api-docs URL은 문서 URL이므로 API_URL로 사용하지 않습니다.

# optional
FINLIFE_API_KEY= # optional
FINLIFE_BASE_URL=https://finlife.fss.or.kr/finlifeapi # optional
FINLIFE_MODE=auto # optional
FINLIFE_FAIL_OPEN_TO_MOCK=0 # optional
FINLIFE_TOPFIN_GRP_LIST=020000 # optional
FINLIFE_SNAPSHOT_TTL_SECONDS=43200 # optional
FINLIFE_SCAN_HARD_CAP_PAGES=200 # optional
FINLIFE_CACHE_TTL_SECONDS=43200 # optional
FINLIFE_FIXTURE_DIR=tmp/finlife-fixtures # optional
FINLIFE_RECORD_FIXTURES=0 # optional (1이면 live 성공 시 fixture 저장)
API_CACHE_STORE= # optional: memory | file | hybrid
API_FILE_CACHE_DIR= # optional: defaults to tmp/api-cache
EXIM_EXCHANGE_CACHE_TTL_SECONDS=21600 # optional

# optional (P1 준비중)
NPS_PENSION_API_KEY= # optional
NPS_PENSION_API_URL= # optional
FSS_INSURANCE_API_KEY= # optional
FSS_INSURANCE_API_URL= # optional
FSC_RETIRE_PENSION_API_KEY= # optional
FSC_RETIRE_PENSION_API_URL= # optional
KDB_RETIRE_GUARANTEE_API_KEY= # optional
KDB_RETIRE_GUARANTEE_API_URL= # optional
FSC_FINCOMPANY_API_KEY= # optional
FSC_FINCOMPANY_API_URL= # optional
BOK_ECOS_API_KEY= # optional
BOK_ECOS_API_URL= # optional
FRED_API_KEY= # optional
KOSIS_API_KEY= # optional

# Planning v2 (snapshot / smoke / debug)
# ECOS key는 위의 BOK_ECOS_API_KEY를 사용
ECOS_LANGUAGE=kr # optional: default kr
ECOS_MAX_ROWS=100 # optional: default 100
ECOS_ENABLED=true # optional: true면 ECOS 우선, 실패 시 fallback
PLANNING_BASE_URL=http://localhost:3100 # optional: planning:v2:smoke:http 대상
PLANNING_DEBUG_ENABLED=false # optional: true + localhost 요청일 때만 /debug/* 노출
PLANNING_MONTE_CARLO_ENABLED=true # optional: false면 Monte Carlo API/Run 저장 비활성화
PLANNING_INCLUDE_PRODUCTS_ENABLED=false # optional: false면 includeProducts 후보 매칭 비활성화
PLANNING_OPTIMIZER_ENABLED=false # optional: true면 Experimental Optimizer API/UI 활성화
PLANNING_PDF_ENABLED=false # optional: true면 /api/planning/v2/runs/{id}/report.pdf 활성화 (폰트/Playwright 필요)
PLANNING_NAMESPACE_ENABLED=false # optional: true면 users/{userId} 네임스페이스 저장
PLANNING_USER_ID=default # optional: namespace 사용 시 대상 userId
PLANNING_USERS_INDEX_PATH=.data/planning/users/index.json # optional
PLANNING_ENCRYPTION_ENABLED=false # optional: true면 profiles/runs at-rest 암호화
PLANNING_ENCRYPTION_PASSPHRASE= # optional: 암호화 passphrase (서버 로컬 전용)

# Prisma engine/network (optional)
# 프록시 URL에 계정정보가 포함될 수 있으므로 로그에 값 전체를 출력하지 마세요.
PRISMA_ENGINES_MIRROR=
PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# GitHub Ops (Dev)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
PLANNING_FEEDBACK_ISSUE_LABELS=planning,feedback
PLANNING_FEEDBACK_ISSUE_PREFIX=[Planning v2]

# Auto Merge (Dev/OPS)
AUTO_MERGE_ENABLED=false
AUTO_MERGE_REQUIRED_CHECKS=CI
AUTO_MERGE_REQUIRED_LABEL=automerge
AUTO_MERGE_MIN_APPROVALS=0
AUTO_MERGE_REQUIRE_CLEAN=false
AUTO_MERGE_CONFIRM_TEMPLATE=MERGE {PR} {SHA7}
AUTO_MERGE_POLICY_PATH=.data/ops/auto-merge-policy.json # optional
