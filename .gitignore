# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

tmp/api-samples/
tmp/api-cache/
tmp/dart/
tmp/finlife-fixtures/
tmp/*.json

# generic build/cache
dist/
.turbo/
coverage/
*.log

# prisma/sqlite local artifacts
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm
*.sqlite
*.sqlite3
*.db

# provider logos (local assets only)
public/providers/*
!public/providers/README.md
/.pnpm-store/
/artifacts/

# runtime data artifacts (keep local only)
.data/ops/
.data/news/
.data/indicators/
.data/alerts/
.data/exposure/
.data/journal/
.data/planning/
.data/planning-e2e/
.data/planning_v3_drafts/
