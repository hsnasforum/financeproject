generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Provider {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  name      String
  aliases   ProviderAlias[]
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id           Int             @id @default(autoincrement())
  finPrdtCd    String          @unique
  kind         String
  name         String?
  providerNameNorm String?
  productNameNorm  String?
  searchTextNorm   String?
  providerId   Int?
  provider     Provider?       @relation(fields: [providerId], references: [id])
  raw          Json?
  options      ProductOption[]
  favorites    Favorite[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  externalMatches ExternalProductMatch[]

  @@index([providerNameNorm])
  @@index([productNameNorm])
  @@index([searchTextNorm])
}

model ProductOption {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  saveTrm   String?
  intrRate  Float?
  intrRate2 Float?
  raw       Json?
}

model UserProfile {
  id               Int               @id @default(autoincrement())
  purpose          String?
  preferredTerms   String?
  liquidityNeed    String?
  ratePreference   String?
  favorites        Favorite[]
  plannerSnapshots PlannerSnapshot[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Favorite {
  id            Int         @id @default(autoincrement())
  userProfileId Int
  productId     Int
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
  createdAt     DateTime    @default(now())

  @@unique([userProfileId, productId])
}

model PlannerSnapshot {
  id                  Int         @id @default(autoincrement())
  userProfileId       Int
  userProfile         UserProfile @relation(fields: [userProfileId], references: [id])
  monthlyIncome       Float?
  monthlyExpense      Float?
  monthlySaving       Float?
  emergencyMonths     Float?
  debtBurdenRatio     Float?
  goalAmount          Float?
  goalMonths          Int?
  assumptions         Json?
  createdAt           DateTime    @default(now())
}

model ProviderAlias {
  id           Int      @id @default(autoincrement())
  providerId   Int
  provider     Provider @relation(fields: [providerId], references: [id])
  aliasRaw     String
  aliasNorm    String
  createdAt    DateTime @default(now())

  @@index([aliasNorm])
  @@unique([providerId, aliasNorm])
}

model ExternalSourceSnapshot {
  id           Int      @id @default(autoincrement())
  sourceId     String
  kind         String
  lastSyncedAt DateTime
  ttlMs        Int
  metaJson     Json?

  @@unique([sourceId, kind])
  @@index([sourceId, kind])
}

model ExternalProduct {
  id               Int      @id @default(autoincrement())
  sourceId         String
  kind             String
  externalKey      String
  providerNameRaw  String
  providerNameNorm String
  productNameRaw   String
  productNameNorm  String
  summary          String?
  rawJson          Json
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  updatedAt        DateTime @updatedAt
  matches          ExternalProductMatch[]

  @@unique([sourceId, kind, externalKey])
  @@index([sourceId, kind, providerNameNorm])
  @@index([sourceId, kind, productNameNorm])
}

model ExternalProductMatch {
  id                Int              @id @default(autoincrement())
  externalProductId Int
  externalProduct   ExternalProduct  @relation(fields: [externalProductId], references: [id], onDelete: Cascade)
  internalProductId Int?
  internalProduct   Product?         @relation(fields: [internalProductId], references: [id], onDelete: SetNull)
  method            String
  confidence        Float
  evidenceJson      Json
  createdAt         DateTime         @default(now())

  @@index([externalProductId, confidence])
  @@index([internalProductId])
}
